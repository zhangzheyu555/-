# Unified Docker runtime settings. Copy to .env and change passwords per environment.

NGINX_IMAGE_TAG=1.27-alpine
GATEWAY_HTTP_BIND_IP=127.0.0.1
HTTP_PORT=8088
OFFICIAL_SITE_ROOT=./deploy/official-site
VITE_PUBLIC_BASE=/admin/

FRONTEND_IMAGE_TAG=local
FRONTEND_BIND_IP=127.0.0.1
FRONTEND_PORT=5173

BACKEND_IMAGE_TAG=local
BACKEND_BIND_IP=127.0.0.1
BACKEND_PORT=8080

INSPECTION_IMAGE_TAG=local
INSPECTION_BIND_IP=127.0.0.1
INSPECTION_PORT=8000

MYSQL_IMAGE_TAG=8.4
MYSQL_BIND_IP=127.0.0.1
MYSQL_HOST_PORT=3306
MYSQL_DATABASE=store_profit_qa
MYSQL_ROOT_PASSWORD=store_profit_root
MYSQL_APP_USER=store_profit_app
MYSQL_APP_PASSWORD=store_profit_app
MYSQL_ALLOW_PUBLIC_KEY_RETRIEVAL=true

REDIS_IMAGE_TAG=8
REDIS_BIND_IP=127.0.0.1
REDIS_HOST_PORT=6379
REDIS_PASSWORD=store_profit_redis

POSTGRES_IMAGE_TAG=17
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_HOST_PORT=5432
POSTGRES_DB=store_profit_aux
POSTGRES_USER=store_profit_pg
POSTGRES_PASSWORD=store_profit_pg

APP_ENV=QA
APP_SEED_DEMO_ENABLED=false
APP_BOOTSTRAP_DEFAULT_USERS_ENABLED=false
APP_BOOTSTRAP_DEFAULT_USERS_PASSWORD=
APP_BOOTSTRAP_STORE_MANAGER_ACCOUNTS_ENABLED=false
APP_BOOTSTRAP_STORE_MANAGER_PASSWORD=
DEEPSEEK_ENABLED=false

# 微信小程序登录（仅后端容器使用；AppSecret 不可提交到仓库）
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_APP_SECRET=
WECHAT_MINI_PROGRAM_BASE_URL=https://api.weixin.qq.com
