# 本文件仅说明变量；实际接口地址按开发/生产模式分别配置到：
# .env.development.local（本机后端）和 .env.production.local（服务器后端）。
# 候选构建由 scripts/build-mobile-candidates.ps1 从当前 Windows 用户的环境变量读取
# MOBILE_STAGING_*_API_BASE_URL，并以该受控值覆盖本地配置。
VITE_API_BASE_URL=http://127.0.0.1:8080
# 仅开发构建：微信开发者工具走上方本机地址；真机调试走此 HTTPS 地址。
# 真实值只写入未跟踪的 .env.development.local，不得提交。
VITE_MOBILE_DEVICE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=
# 后端同时提供 /api/auth/wechat/login、bind、binding 三个接口后才可开启。
VITE_WECHAT_AUTH_ENABLED=false
