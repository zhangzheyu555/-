{
  "name": "ai-profit-os-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "AI Profit OS mobile clients for H5, WeChat Mini Program and native App",
  "engines": {
    "node": ">=20 <21"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:app": "uni -p app-plus",
    "build:h5": "cross-env UNI_OUTPUT_DIR=dist/candidate/h5 uni build",
    "build:mp-weixin": "cross-env UNI_OUTPUT_DIR=dist/build/mp-weixin uni build -p mp-weixin",
    "build:mp-weixin:candidate": "cross-env UNI_OUTPUT_DIR=dist/candidate/mp-weixin uni build -p mp-weixin",
    "build:app:android": "cross-env MOBILE_TARGET_OS=android UNI_OUTPUT_DIR=dist/candidate/android uni build -p app-plus",
    "build:app:ios": "cross-env MOBILE_TARGET_OS=ios UNI_OUTPUT_DIR=dist/candidate/ios uni build -p app-plus",
    "build:all": "npm run build:h5 && npm run build:mp-weixin && npm run build:app:android && npm run build:app:ios",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-plus": "3.0.0-4080420251103001",
    "@dcloudio/uni-components": "3.0.0-4080420251103001",
    "@dcloudio/uni-h5": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080420251103001",
    "pinia": "^2.3.1",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.5"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-cli-shared": "3.0.0-4080420251103001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080420251103001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
    "@vue/runtime-core": "^3.4.21",
    "@vue/tsconfig": "^0.1.3",
    "cross-env": "^7.0.3",
    "sass": "^1.77.8",
    "typescript": "^4.9.4",
    "vite": "5.2.8",
    "vue-tsc": "^1.0.24"
  }
}
