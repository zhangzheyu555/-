# 仅复制到当前 Windows 用户的未跟踪配置中，或由受控 CI 注入。
# 不要填写真实地址到本示例文件、源码、日志或命令行。
# 候选构建要求四个变量都为可访问的 HTTPS 地址；拒绝 localhost、*.invalid、
# mobile-api.invalid 和含用户名/密码的 URL。
MOBILE_STAGING_H5_API_BASE_URL=
MOBILE_STAGING_MP_WEIXIN_API_BASE_URL=
# 仅用于 mp-weixin 候选构建；由当前进程环境或受控 CI 注入临时源码目录。
# 不要把真实 AppID 写入任何 .env 文件、日志、构建证据或 Git 仓库。
MOBILE_STAGING_MP_WEIXIN_APP_ID=
MOBILE_STAGING_ANDROID_API_BASE_URL=
MOBILE_STAGING_IOS_API_BASE_URL=
