# =====================================================================
# AI-Profit-OS 生产启动配置模板（三服务：YOLO 巡检 + 经营助手 + 员工助手）
# ---------------------------------------------------------------------
# 用法（在服务器上，与 docker-compose.yml 同一目录 src/ 下执行）：
#   1) cp production.env.example .env
#   2) 编辑 .env，把所有 <请填写...> 和 CHANGE_ME 换成真实值
#   3) docker compose up -d --build
#   4) 验证：docker compose ps         # 六个容器都应为 healthy
#            docker compose logs -f backend
#
# 三个服务如何启动：
#   - YOLO 巡检服务 inspection-service：镜像内已打包模型，compose 自动构建启动，无需密钥。
#   - 门店经营助手：后端进程内置，靠下方 DEEPSEEK_* 接入 DeepSeek。
#   - 员工服务助手：后端进程内置，靠下方 EMPLOYEE_ASSISTANT_* 以 MODEL 模式接入 DeepSeek。
#
# 关键约束（务必遵守，否则助手会显示“未配置/不可用”）：
#   - 要让两个助手真实调用 DeepSeek，APP_ENV 必须是 PRODUCTION（或 STAGING），不能是 QA/TEST。
#     QA/TEST 环境只允许连本机 Mock，会拦截一切公网出网。
#   - 员工助手 ASSISTANT_RUNTIME_SECURED 必须为 true。
#   - 服务器需能访问 https://api.deepseek.com:443（DNS 正常、TLS 1.2+）。
# =====================================================================

# ---------- 运行环境 ----------
# 生产必须为 PRODUCTION，否则 DeepSeek / 员工助手出网会被拦截。
APP_ENV=PRODUCTION

# ---------- 对外网关（Nginx，唯一公网入口）----------
NGINX_IMAGE_TAG=1.27-alpine
GATEWAY_HTTP_BIND_IP=0.0.0.0
HTTP_PORT=80
GATEWAY_HTTPS_BIND_IP=0.0.0.0
HTTPS_PORT=443
OFFICIAL_SITE_ROOT=./deploy/official-site
VITE_PUBLIC_BASE=/admin/
# 前端访问地址：http(s)://你的域名/admin/ ，后端 API 走同源 /api，由网关反代。
# HTTPS 需把证书放到 src/ssl/ 目录（fullchain.pem / privkey.pem，见 deploy/nginx-unified.conf）。

# ---------- 前端 / 后端 / 巡检服务（默认只绑本机，仅网关对公网）----------
FRONTEND_IMAGE_TAG=local
FRONTEND_BIND_IP=127.0.0.1
FRONTEND_PORT=5173

BACKEND_IMAGE_TAG=local
BACKEND_BIND_IP=127.0.0.1
BACKEND_PORT=8080

# YOLO 巡检服务：模型已打包进镜像，无需任何密钥；保持只绑本机即可。
INSPECTION_IMAGE_TAG=local
INSPECTION_BIND_IP=127.0.0.1
INSPECTION_PORT=8000

# ---------- MySQL（生产务必改强密码）----------
MYSQL_IMAGE_TAG=8.4
MYSQL_BIND_IP=127.0.0.1
MYSQL_HOST_PORT=3306
MYSQL_DATABASE=store_profit_prod
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root_strong_password
MYSQL_APP_USER=store_profit_app
MYSQL_APP_PASSWORD=CHANGE_ME_mysql_app_strong_password
MYSQL_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# ---------- Redis / Postgres（生产务必改强密码）----------
REDIS_IMAGE_TAG=8
REDIS_BIND_IP=127.0.0.1
REDIS_HOST_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_strong_password

POSTGRES_IMAGE_TAG=17
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_HOST_PORT=5432
POSTGRES_DB=store_profit_aux
POSTGRES_USER=store_profit_pg
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password

# ---------- 首次启动引导登录账号 ----------
# 全新空库首启时设为 true 生成默认账号，登录一次确认后改回 false 再重启，避免每次覆盖。
# 已导入正式数据库（含账号）时保持 false。
APP_SEED_DEMO_ENABLED=false
APP_BOOTSTRAP_DEFAULT_USERS_ENABLED=false
APP_BOOTSTRAP_DEFAULT_USERS_PASSWORD=
APP_BOOTSTRAP_STORE_MANAGER_ACCOUNTS_ENABLED=false
APP_BOOTSTRAP_STORE_MANAGER_PASSWORD=

# =====================================================================
# 服务①/② 门店经营助手 —— 接入 DeepSeek
# =====================================================================
DEEPSEEK_ENABLED=true
DEEPSEEK_API_KEY=<请填写 DeepSeek API Key，形如 sk-xxxxxxxx>
DEEPSEEK_BASE_URL=https://api.deepseek.com
# PRODUCTION 下 LIVE 即可真实出网（QA 才需要 pilot 标记）。
DEEPSEEK_OUTBOUND_MODE=LIVE
# 模型名必须是你的 DeepSeek 账号实际支持的，官方常见为 deepseek-chat / deepseek-reasoner。
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_FAST_MODEL=deepseek-chat

# =====================================================================
# 服务③ 员工服务助手 —— MODEL 模式独立接入 DeepSeek
# （独立密钥，绝不复用上面的 DEEPSEEK_*；建议在 DeepSeek 控制台单独建一把 Key）
# =====================================================================
EMPLOYEE_ASSISTANT_PROVIDER=MODEL
EMPLOYEE_ASSISTANT_MODEL_URL=https://api.deepseek.com
EMPLOYEE_ASSISTANT_MODEL_API_KEY=<请填写员工助手专用的 DeepSeek API Key>
EMPLOYEE_ASSISTANT_MODEL_NAME=deepseek-chat
EMPLOYEE_ASSISTANT_OUTBOUND_MODE=LIVE
# 必须为 true，否则员工助手拒绝就绪（提示“未通过安全启动器注入”）。
ASSISTANT_RUNTIME_SECURED=true

# ---------- 前端跨域（走网关同源时一般无需改；如前端独立域名再填）----------
APP_CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# ---------- 微信小程序登录（可选，不用留空）----------
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_APP_SECRET=
WECHAT_MINI_PROGRAM_BASE_URL=https://api.weixin.qq.com
